{
  "name": "linchpin",
  "description": "A lightweight personal browser toolkit for Reddit, search, media, JSON, and AI summaries.",
  "private": true,
  "version": "0.3.0",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox --mv3",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox --mv3",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox --mv3",
    "compile": "tsc --noEmit",
    "export:res-tags": "node scripts/export-res-tags.mjs",
    "postinstall": "wxt prepare && (npm run skills:update || true)",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "skills:install": "npx skills add 46ki75/claude-plugins -s wxt -a cursor -a codex -y",
    "skills:update": "npx skills update wxt -p -y || npm run skills:install"
  },
  "devDependencies": {
    "classic-level": "^3.0.0",
    "prettier": "3.9.5",
    "typescript": "^5.9.3",
    "wxt": "^0.20.27"
  },
  "dependencies": {
    "@mozilla/readability": "^0.6.0",
    "dompurify": "^3.4.12",
    "marked": "^18.0.6",
    "tom-select": "^2.6.2"
  }
}
